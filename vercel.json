{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron",              "schedule": "0 5 * * *" },
    { "path": "/api/solo-queue-cron",   "schedule": "0 6 * * 0" }
  ],
  "functions": {
    "api/solo-queue-cron.ts": { "maxDuration": 800 }
  }
}
